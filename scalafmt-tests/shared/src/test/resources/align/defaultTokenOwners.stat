align.tokens."+" = ["="]
<<< don't align independent columns (see #1896)
object fmt {
  val header = JwtHeader(algorithm = Some(JwtAlgorithm.HMD5))
  val content = payload.toString
  val claim = JwtClaim(content = content)
}
>>>
object fmt {
  val header  = JwtHeader(algorithm = Some(JwtAlgorithm.HMD5))
  val content = payload.toString
  val claim   = JwtClaim(content = content)
}
<<< respect specified owner
align.tokens."+" = [{code = "=", owner = "(Term.Assign|Defn.Val)"}]
===
object fmt {
  val header = JwtHeader(algorithm = Some(JwtAlgorithm.HMD5))
  val content = payload.toString
  val claim = JwtClaim(content = content)
}
>>>
object fmt {
  val header  = JwtHeader(algorithm = Some(JwtAlgorithm.HMD5))
  val content = payload.toString
  val claim   = JwtClaim(content = content)
}
<<< fallback to any owner
align.tokens."+" = ["!"]
===
object fmt {
  aaa ! 2
  bb ! 3
}
>>>
object fmt {
  aaa ! 2
  bb  ! 3
}
<<< empty code aligns param names after annotations, regardless of text
align.tokens."+" = [{ code = "", owners = [{ regex = "Term\\.Name", parents = ["Term.Param"] }] }]
===
case class UserCreateCommand(
    @MinLength(3) @MaxLength(30) username: String,
    @Pattern("^[a-z0-9-]+$") slug: String,
    @Email email: String,
    @Min(0) @Max(150) age: Int,
    @MinSize(1) @MaxSize(10) zoneIds: Vector[ZoneId]
)
>>>
case class UserCreateCommand(
    @MinLength(3) @MaxLength(30) username: String,
    @Pattern("^[a-z0-9-]+$")     slug: String,
    @Email                       email: String,
    @Min(0) @Max(150)            age: Int,
    @MinSize(1) @MaxSize(10)     zoneIds: Vector[ZoneId]
)
<<< empty code also aligns def param names
align.tokens."+" = [{ code = "", owners = [{ regex = "Term\\.Name", parents = ["Term.Param"] }] }]
===
def f(
    @unused a: Int,
    @deprecated("x", "y") bbb: String
): Unit = ()
>>>
def f(
    @unused               a: Int,
    @deprecated("x", "y") bbb: String
): Unit = ()
<<< empty code: a blank line splits into independent align blocks
align.tokens."+" = [{ code = "", owners = [{ regex = "Term\\.Name", parents = ["Term.Param"] }] }]
===
def f(
    @unused a: Int,
    @deprecated("x", "y") bbb: String,

    @unused cc: Int,
    @deprecated("w") d: String,
): Unit = ()
>>>
def f(
    @unused               a: Int,
    @deprecated("x", "y") bbb: String,

    @unused          cc: Int,
    @deprecated("w") d: String
): Unit = ()
